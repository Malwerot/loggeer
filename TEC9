-- Kavo UI Library Init
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Marshmallow Farm Hub", "GrapeTheme")

-- Servicos e Variáveis
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local farmConnection
local targetPot = nil -- Variável que vai "alocar" a panela próxima
local currentIndex = 1
local farmTimer = 0
local equipPending = false
local equipTimer = 0
local EQUIP_DELAY = 0.3

local farmItems = {
    {name = "Water", cooldown = 0.5},
    {name = "Sugar Block Bag", cooldown = 22},
    {name = "Gelatin", cooldown = 2.8},
    {name = "Empty Bag", cooldown = 47},
}

-- ==========================================
-- Funções de Inteligência e Busca
-- ==========================================

local function getRandomDelay(min, max)
    return math.random(min * 100, max * 100) / 100
end

-- Busca a panela mais próxima uma única vez
local function findNearestPot()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = character.HumanoidRootPart.Position
    local closest = nil
    local shortestDist = math.huge

    local locations = {
        Workspace.Map.Houses.WH1:FindFirstChild("Interior"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 1"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 2"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 3"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 4")
    }

    for _, loc in ipairs(locations) do
        if loc then
            for _, child in ipairs(loc:GetChildren()) do
                if child.Name == "Cooking Pot" then
                    local dist = (child.Position - myPos).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closest = child
                    end
                end
            end
        end
    end
    
    -- Só aceita se a panela estiver a uma distância razoável (ex: 20 studs)
    return (shortestDist < 20) and closest or nil
end

local function countItems(itemName)
    local count = 0
    local backpack = LocalPlayer.Backpack
    local character = LocalPlayer.Character
    local items = backpack:GetChildren()
    if character then
        for _, v in ipairs(character:GetChildren()) do table.insert(items, v) end
    end
    for _, item in ipairs(items) do
        if item:IsA("Tool") and item.Name == itemName then count = count + 1 end
    end
    return count
end

local function equipItem(itemName)
    local character = LocalPlayer.Character
    local tool = LocalPlayer.Backpack:FindFirstChild(itemName)
    if character and tool then
        character.Humanoid:EquipTool(tool)
        return true
    end
    return false
end

-- Interage APENAS com a panela alocada
local function pressE()
    if targetPot then
        local att = targetPot:FindFirstChild("Attachment")
        local pp = att and att:FindFirstChild("ProximityPrompt")
        if pp then fireproximityprompt(pp) end
    end
end

-- ==========================================
-- Autofarm Otimizado
-- ==========================================

local function startAutoFarm()
    stopAutoFarm() -- Garante que não haja conexões duplicadas
    
    -- ALOCAÇÃO: Procura a panela no momento que liga
    targetPot = findNearestPot()
    
    if not targetPot then
        game.StarterGui:SetCore("SendNotification", {
            Title = "Erro de Farm",
            Text = "Fique perto de uma panela antes de ligar!",
            Duration = 5
        })
        return
    end

    farmConnection = RunService.Heartbeat:Connect(function(dt)
        farmTimer = farmTimer + dt

        if equipPending then
            equipTimer = equipTimer + dt
            if equipTimer >= (EQUIP_DELAY + getRandomDelay(0.05, 0.2)) then
                pressE()
                equipPending = false
                equipTimer = 0
                farmTimer = 0
            end
        elseif farmTimer >= (farmItems[currentIndex].cooldown + getRandomDelay(0.1, 0.5)) then
            if equipItem(farmItems[currentIndex].name) then
                equipPending = true
                equipTimer = 0
            end
            currentIndex = currentIndex % #farmItems + 1
            farmTimer = 0
        end
    end)
end

function stopAutoFarm()
    if farmConnection then farmConnection:Disconnect() end
    farmConnection = nil
    targetPot = nil -- LIMPA A ALOCAÇÃO
    equipPending = false
    farmTimer = 0
end

-- ==========================================
-- Interface Kavo UI
-- ==========================================

local Tab = Window:NewTab("Serviços")
local FarmSection = Tab:NewSection("Auto Farm Inteligente")

FarmSection:NewToggle("Auto Cooking Pot", "Trava na panela mais próxima ao ligar", function(state)
    if state then startAutoFarm() else stopAutoFarm() end
end)

local NPCSection = Tab:NewSection("Interações")
NPCSection:NewButton("Falar com Lamont Bell", "Interação segura", function()
    pcall(function()
        local pp = Workspace.Folders.NPCs["Lamont Bell"].UpperTorso.ProximityPrompt
        fireproximityprompt(pp)
    end)
end)

local InfoSection = Tab:NewSection("Inventário")
InfoSection:NewButton("Calcular Marshmallows", "Ver estoque", function()
    local p = math.min(countItems("Sugar Block Bag"), countItems("Water"), countItems("Gelatin"))
    game.StarterGui:SetCore("SendNotification", {Title = "Estoque", Text = "Pode fazer: "..p, Duration = 5})
end)

local ConfigSection = Window:NewTab("Config"):NewSection("UI")
ConfigSection:NewKeybind("Esconder UI", "Alternar visibilidade", Enum.KeyCode.RightShift, function()
    Library:ToggleUI()
end)
