-- Construção da Kavo UI
-- ==========================================

local Tab = Window:NewTab("Serviços")

-- Seção Auto Farm
local FarmSection = Tab:NewSection("Auto Farm")

FarmSection:NewToggle("Auto Cooking Pot", "Liga e desliga o farm automático nos fogões", function(state)
