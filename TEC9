-- Kavo UI Library Init
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Marshmallow Farm Hub", "BloodTheme")

-- Serviços e Variáveis
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local farmConnection
local targetPot = nil 
local currentIndex = 1
local farmTimer = 0
local equipPending = false
local equipTimer = 0
local EQUIP_DELAY = 0.3
local isPressing = false -- Trava de segurança (Debounce)

local farmItems = {
    {name = "Water", cooldown = 0.5},
    {name = "Sugar Block Bag", cooldown = 22},
    {name = "Gelatin", cooldown = 2.8},
    {name = "Empty Bag", cooldown = 47},
}

-- ==========================================
-- Sistema de Balanço Financeiro
-- ==========================================

local PRECOS_BAGS = {
    ["Small Marshmallow Bag"] = 1470,
    ["Medium Marshmallow Bag"] = 2840,
    ["Large Marshmallow Bag"] = 4250
}

local function calcularVendaTotal()
    local totalDinheiro = 0
    local quantidadeTotal = 0
    
    -- Verifica mochila e o que está na mão (Character)
    local containers = {LocalPlayer.Backpack, LocalPlayer.Character}
    
    for _, folder in ipairs(containers) do
        if folder then
            for _, item in ipairs(folder:GetChildren()) do
                if PRECOS_BAGS[item.Name] then
                    totalDinheiro = totalDinheiro + PRECOS_BAGS[item.Name]
                    quantidadeTotal = quantidadeTotal + 1
                end
            end
        end
    end
    
    return totalDinheiro, quantidadeTotal
end

-- ==========================================
-- Funções de Inteligência e Busca
-- ==========================================

local function getRandomDelay(min, max)
    return math.random(min * 100, max * 100) / 100
end

local function findNearestPot()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = character.HumanoidRootPart.Position
    local closest = nil
    local shortestDist = 30 

    local locations = {
        Workspace.Map.Houses:FindFirstChild("WH1") and Workspace.Map.Houses.WH1:FindFirstChild("Interior"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 1"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 2"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 3"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 4")
    }

    for _, loc in ipairs(locations) do
        if loc then
            for _, child in ipairs(loc:GetChildren()) do
                if child.Name == "Cooking Pot" and child:IsA("BasePart") then
                    local dist = (child.Position - myPos).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closest = child
                    end
                end
            end
        end
    end
    return closest
end

local function countItems(itemName)
    local count = 0
    local backpack = LocalPlayer.Backpack
    local character = LocalPlayer.Character
    local items = backpack:GetChildren()
    if character then
        for _, v in ipairs(character:GetChildren()) do 
            if v:IsA("Tool") then table.insert(items, v) end 
        end
    end
    for _, item in ipairs(items) do
        if item.Name == itemName then count = count + 1 end
    end
    return count
end

local function equipItem(itemName)
    local character = LocalPlayer.Character
    local tool = LocalPlayer.Backpack:FindFirstChild(itemName)
    if character and tool then
        character.Humanoid:EquipTool(tool)
        return true
    end
    return false
end

-- FIX: Interação Seca (Evita o clique duplo lento)
local function pressE()
    if targetPot and targetPot.Parent and not isPressing then
        isPressing = true
        local att = targetPot:FindFirstChild("Attachment")
        local pp = att and att:FindFirstChild("ProximityPrompt")
        if pp then 
            fireproximityprompt(pp) 
        end
        task.wait(0.2) -- Respiro necessário para o jogo registrar
        isPressing = false
    end
end

-- ==========================================
-- Autofarm Otimizado e Blindado
-- ==========================================

local function stopAutoFarm()
    if farmConnection then farmConnection:Disconnect() end
    farmConnection = nil
    targetPot = nil
    equipPending = false
    isPressing = false
    farmTimer = 0
    currentIndex = 1
end

local function startAutoFarm()
    stopAutoFarm() 
    targetPot = findNearestPot()
    
    if not targetPot then
        game.StarterGui:SetCore("SendNotification", {
            Title = "Erro de Proximidade",
            Text = "Fique ao lado da panela!",
            Duration = 5
        })
        return
    end

    local missingTimer = 5 -- Inicia em 5 para mandar o alerta imediatamente se faltar algo

    farmConnection = RunService.Heartbeat:Connect(function(dt)
        farmTimer = farmTimer + dt

        if equipPending then
            equipTimer = equipTimer + dt
            if equipTimer >= (EQUIP_DELAY + getRandomDelay(0.05, 0.1)) then
                pressE() 
                equipPending = false
                equipTimer = 0
                farmTimer = 0
                
                -- MÁGICA: Só avança pro próximo ingrediente DEPOIS de interagir!
                currentIndex = currentIndex % #farmItems + 1
            end
        elseif farmTimer >= (farmItems[currentIndex].cooldown + getRandomDelay(0.1, 0.4)) then
            local currentItemName = farmItems[currentIndex].name
            
            -- Tenta equipar o item
            if equipItem(currentItemName) then
                equipPending = true
                equipTimer = 0
                missingTimer = 5 -- Reseta o alerta de falta de item
            else
                -- SISTEMA DE AVISO: Se o item não está na mochila
                missingTimer = missingTimer + dt
                if missingTimer >= 5 then -- Manda a notificação a cada 5 segundos
                    game.StarterGui:SetCore("SendNotification", {
                        Title = "Estoque Vazio!",
                        Text = "Vá comprar: " .. currentItemName,
                        Duration = 3
                    })
                    missingTimer = 0
                end
            end
        end
    end)
end

