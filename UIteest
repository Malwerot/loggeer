-- Serviços
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- =========================
-- LÓGICA DE FARM
-- =========================
local farmConnection
local marshmallowConnection
local currentIndex, farmTimer, equipPending, equipTimer = 1, 0, false, 0
local EQUIP_DELAY = 0.3

local farmItems = {
    {name = "Water", cooldown = 0.5},
    {name = "Sugar Block Bag", cooldown = 22},
    {name = "Gelatin", cooldown = 2.8},
    {name = "Empty Bag", cooldown = 47},
}

local function getTools()
    local tools = {}
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if item:IsA("Tool") then table.insert(tools, item) end
    end
    local character = LocalPlayer.Character
    if character then
        for _, item in ipairs(character:GetChildren()) do
            if item:IsA("Tool") then table.insert(tools, item) end
        end
    end
    return tools
end

local function getInventory()
    local names = {}
    for _, tool in ipairs(getTools()) do
        table.insert(names, tool.Name)
    end
    return names
end

local function countItems(itemName)
    local count = 0
    for _, tool in ipairs(getTools()) do
        if tool.Name == itemName then count = count + 1 end
    end
    return count
end

local function countMarshmallows()
    return math.min(
        countItems("Sugar Block Bag"),
        countItems("Water"),
        countItems("Gelatin")
    )
end

local function equipItem(itemName)
    local character = LocalPlayer.Character
    if not character then return false end
    local tool = LocalPlayer.Backpack:FindFirstChild(itemName)
    if tool then
        local hum = character:FindFirstChild("Humanoid")
        if hum then hum:EquipTool(tool) return true end
    end
    return false
end

local function pressLamontBell()
    local ok, err = pcall(function()
        local npc = Workspace.Folders.NPCs:FindFirstChild("Lamont Bell")
        if npc then
            local pp = npc:FindFirstChild("UpperTorso"):FindFirstChild("ProximityPrompt")
            if pp then
                pp.HoldDuration = 0
                fireproximityprompt(pp)
            end
        end
    end)
    if not ok then warn("Erro ao interagir com Lamont Bell:", err) end
end

local function startAutoFarm()
    if farmConnection then farmConnection:Disconnect() end
    farmTimer, equipPending, currentIndex = 0, false, 1
    farmConnection = RunService.Heartbeat:Connect(function(dt)
        farmTimer = farmTimer + dt
        if equipPending then
            equipTimer = equipTimer + dt
            if equipTimer >= EQUIP_DELAY then
                equipPending, equipTimer, farmTimer = false, 0, 0
            end
        elseif farmTimer >= farmItems[currentIndex].cooldown then
            if equipItem(farmItems[currentIndex].name) then
                equipPending, equipTimer = true, 0
            end
            currentIndex = currentIndex % #farmItems + 1
            farmTimer = 0
        end
    end)
end

local function stopAutoFarm()
    if farmConnection then farmConnection:Disconnect() farmConnection = nil end
    equipPending, equipTimer, farmTimer, currentIndex = false, 0, 0, 1
end

-- =========================
-- UI ORIONLIB
-- =========================
local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Orion/main/source"))()

local Window = OrionLib:MakeWindow({
    Name = "AXIOS Farm Hub",
    HidePremium = false,
    SaveConfig = false,
    ConfigFolder = "AXIOSFarm"
})

local FarmTab = Window:MakeTab({
    Name = "Farm",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

FarmTab:AddToggle({
    Name = "Iniciar AutoFarm",
    Default = false,
    Callback = function(state)
        if state then startAutoFarm() else stopAutoFarm() end
    end
})

FarmTab:AddButton({
    Name = "AutoSell Lamont Bell",
    Callback = function()
        pressLamontBell()
    end
})

FarmTab:AddButton({
    Name = "Mostrar Inventário",
    Callback = function()
        local inv = getInventory()
        OrionLib:MakeNotification({
            Name = "Inventário",
            Content = #inv > 0 and table.concat(inv, ", ") or "Inventário vazio",
            Time = 5
        })
    end
})

local marshmallowLabel = FarmTab:AddLabel("🍡 Você pode cozinhar até 0 marshmallows")

FarmTab:AddToggle({
    Name = "Contador de Marshmallows",
    Default = false,
    Callback = function(state)
        if state then
            marshmallowConnection = task.spawn(function()
                while task.wait(1) do
                    if not marshmallowConnection then break end
                    marshmallowLabel:Set("🍡 Você pode cozinhar até " .. countMarshmallows() .. " marshmallows")
                end
            end)
        else
            marshmallowConnection = nil
        end
    end
})

OrionLib:Init()
