-- Serviços
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Variáveis globais
local autoInteractEnabled = false
local interactConnection
local homelessList = {
    "One","Two","Three","Four","Five","Six","Seven","Eight","Nine","Ten",
    "Eleven","Twelve","Thirteen","Fourteen","Fifteen","Sixteen","Seventeen","Eighteen","Nineteen","Twenty"
}
local currentIndex = 1
local cooldownTimer = 0
local currentCooldown = math.random(1,2)

-- Função para interagir com o HomelessPeople atual
local function pressE()
    local name = homelessList[currentIndex]
    local person = Workspace.Folders.HomelessPeople:FindFirstChild(name)
    if person then
        local torso = person:FindFirstChild("UpperTorso")
        if torso then
            local prompt = torso:FindFirstChild("ProximityPrompt")
            if prompt then
                -- remove limite de distância
                prompt.MaxActivationDistance = 999999
                fireproximityprompt(prompt)
            end
        end
    end
    -- avança para o próximo
    currentIndex = currentIndex % #homelessList + 1
    -- define novo cooldown aleatório
    currentCooldown = math.random(1,2)
end

-- Loop de interação com cooldown aleatório
local function startAutoInteract()
    if interactConnection then interactConnection:Disconnect() end
    currentIndex = 1
    cooldownTimer = 0
    currentCooldown = math.random(1,2)

    interactConnection = RunService.Heartbeat:Connect(function(dt)
        if not autoInteractEnabled then
            interactConnection:Disconnect()
            interactConnection = nil
            return
        end

        cooldownTimer = cooldownTimer + dt
        if cooldownTimer >= currentCooldown then
            pressE()
            cooldownTimer = 0
        end
    end)
end

local function stopAutoInteract()
    autoInteractEnabled = false
    if interactConnection then
        interactConnection:Disconnect()
        interactConnection = nil
    end
end

-- UI
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Malwerot/test1/refs/heads/main/UUII.lua"))()
local Window = Library.CreateLib("HomelessPeople Interactor", "DarkTheme")

local TabInteract = Window:NewTab("Interactor")
local SectionInteract = TabInteract:NewSection("Controle")

SectionInteract:NewToggle("ON/OFF", "Liga ou desliga interação automática", function(state)
    autoInteractEnabled = state
    if state then
        startAutoInteract()
    else
        stopAutoInteract()
    end
end)
