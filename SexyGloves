local Window = Rayfield:CreateWindow({
    Name = "AXIOS | BH4L",
    LoadingTitle = "AXIOS",
    LoadingSubtitle = "Iniciando no modo Clean...",
    Theme = "Default", -- Define para iniciar no Default como você pediu
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "LimbConfigs",
        FileName = "Config"
    },
})

local AutoTab = Window:CreateTab("AutoFarm", "badge-dollar-sign")
local ThemesTab = Window:CreateTab("Themes", "palette")

-- Toggle do Farm
AutoTab:CreateToggle({
    Name = "Auto Cooking Pot",
    CurrentValue = false,
    Flag = "FarmToggle",
    Callback = function(Value)
        if Value then startAutoFarm() else if farmConnection then farmConnection:Disconnect() end end
    end,
})

